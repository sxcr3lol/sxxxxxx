local function UpdateTriggerFOV()
    local Config = GetConfig()
    local TriggerCfg = Config and Config["Trigger Bot"]
    if not TriggerCfg or not TriggerCfg["Configuration"] or not TriggerCfg["Configuration"]["Enabled"] then
        if LastFrame.TriggerFOVVisible then
            TriggerFOVBox.Visible = false
            LastFrame.TriggerFOVVisible = false
        end
        return
    end
    
    ValidateTarget("Trigger")
    
    local TriggerTarget = State.Targets.Trigger
    
    local FOVVis = false
    local FOVCfg = TriggerCfg["FOV"] or {}
    local FOVEnabled = FOVCfg["Configuration"] and FOVCfg["Configuration"]["Enabled"]
    local Visualize = FOVCfg["Configuration"] and FOVCfg["Configuration"]["Visualize"]
    
    if FOVEnabled and Visualize and TriggerTarget then
        local Char = TriggerTarget.Character
        local Root = Char and Char:FindFirstChild("HumanoidRootPart")
        if Root then
            local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Root.Position)
            if OnScreen and ScreenPos.Z > 1 then
                local Size = FOVCfg["Configuration"]["Size"] or { X = 11, Y = 11, Z = 11 }
                local ViewportX, ViewportY = Camera.ViewportSize.X, Camera.ViewportSize.Y
                local CamFOV = Camera.FieldOfView
                local Scale = (Root.Size.Y * ViewportY) / (ScreenPos.Z * 2) * 80 / CamFOV
                local W = math.min((Size.X or 11) * Scale, ViewportX * 2)
                local H = math.min((Size.Y or 11) * Scale, ViewportY * 2)
                TriggerFOVBox.Size = Vector2.new(math.floor(W + 0.5), math.floor(H + 0.5))
                TriggerFOVBox.Position = Vector2.new(math.floor(ScreenPos.X - W/2 + 0.5), math.floor(ScreenPos.Y - H/2 + 0.5))
                local MousePos = UserInputService:GetMouseLocation()
                local Delta = Vector2.new(ScreenPos.X, ScreenPos.Y) - MousePos
                local InBox = math.abs(Delta.X) <= W/2 and math.abs(Delta.Y) <= H/2
                local BaseColor = FOVCfg["Configuration"]["Color"] or Color3.new(1, 0, 0)
                TriggerFOVBox.Color = BaseColor
                FOVVis = true
            end
        end
    end
    if FOVVis ~= LastFrame.TriggerFOVVisible then
        TriggerFOVBox.Visible = FOVVis
        LastFrame.TriggerFOVVisible = FOVVis
    end
end

local function UpdateSilentFOV()
    local Config = GetConfig()
    local SilentCfg = Config and Config["Silent Aimbot"]
    local SilentEnabled = SilentCfg and SilentCfg["Configuration"] and SilentCfg["Configuration"]["Enabled"]
    if not SilentEnabled then
