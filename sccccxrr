    local function clearMesh(tool, original)
        for _, child in ipairs(tool:GetChildren()) do
            if child.Name == "CurrentSkin" or (child:IsA("MeshPart") and child ~= original) then
                child:Destroy()
            end
        end
    end

    local function applyBat(tool, name)
        local mesh = nil
        local descendants = tool:GetDescendants()
        
        for i = 1, #descendants do
            local v = descendants[i]
            if v:IsA("MeshPart") and v.Transparency == 0 then
                mesh = v
                break
            end
        end
        
        if not mesh then
            return
        end
        
        local batSkins = ReplicatedStorage:FindFirstChild("SkinModules")
        
        if not batSkins then
            return
        end
        
        batSkins = batSkins:FindFirstChild("Bats")
        
        if not batSkins then
            return
        end
        
        local skin = batSkins:FindFirstChild(name)
        
        if not skin then
            return
        end
        
        local clone = skin:Clone()
        clone.Parent = tool
        clone.CFrame = mesh.CFrame
        clone.Name = "CurrentSkin"
        
        local weld = Instance.new("Weld")
        weld.Part0 = clone
        weld.Part1 = mesh
        weld.Parent = clone
        
        mesh.Transparency = 1
    end

    local function applyGun(tool, name)
        local original = tool:FindFirstChildOfClass("MeshPart")
        
        if not original then
            return
        end
        
        local skinModules = ReplicatedStorage:FindFirstChild("SkinModules")
        
        if not skinModules then
            return
        end
        
        local success, skinData = pcall(function()
            return require(skinModules)
        end)
        
        if not success or not skinData then
            return
        end
        
        local toolName = tool.Name
        local info = skinData[toolName] and skinData[toolName][name]
        
        if not info then
            return
        end
        
        clearMesh(tool, original)
        
        local skinPart = info.TextureID
        
        if typeof(skinPart) == "Instance" then
            local clone = skinPart:Clone()
            clone.Parent = tool
            clone.CFrame = original.CFrame
            clone.Name = "CurrentSkin"
            
            local weld = Instance.new("Weld")
            weld.Part0 = clone
            weld.Part1 = original
            weld.C0 = info.CFrame:Inverse()
            weld.Parent = clone
            
            original.Transparency = 1
        else
            original.TextureID = skinPart
            original.Transparency = 0
        end
        
        local handle = tool:FindFirstChild("Handle")
        
        if not handle then
            return
        end
        
        local shootSound = handle:FindFirstChild("ShootSound")
        
        if shootSound then
            local skinAssets = ReplicatedStorage:FindFirstChild("SkinAssets")
            
            if skinAssets then
                local gunSounds = skinAssets:FindFirstChild("GunShootSounds")
                
                if gunSounds then
                    local sounds = gunSounds:FindFirstChild(toolName)
                    local soundObject = sounds and sounds:FindFirstChild(name)
                    
                    if soundObject then
                        shootSound.SoundId = soundObject.Value
                    end
                end
            end
        end
        
        local skinAssets = ReplicatedStorage:FindFirstChild("SkinAssets")
        
        if skinAssets then
            local particleFolder = skinAssets:FindFirstChild("GunHandleParticle")
            
            if particleFolder then
                local particleSource = particleFolder:FindFirstChild(name)
                
                if particleSource then
                    local particleEmitter = particleSource:FindFirstChild("ParticleEmitter")
                    
                    if particleEmitter then
                        for _, existing in ipairs(handle:GetChildren()) do
                            if existing:IsA("ParticleEmitter") then
                                existing:Destroy()
                            end
                        end
                        
                        particleEmitter:Clone().Parent = handle
                    end
                end
            end
        end
        
        handle:SetAttribute("SkinName", name)
    end

    local function cleanKnife(tool)
        local data = knifeData[tool]
        
        if data then
            if data.track then
                data.track:Stop()
                data.track:Destroy()
                data.track = nil
            end
            
            if data.welds then
                for _, weld in ipairs(data.welds) do
                    if weld then
                        weld:Destroy()
                    end
                end
            end
        end
        
        local mesh = tool:FindFirstChild("Default")
        
        if mesh then
            local children = mesh:GetChildren()
            
            for i = 1, #children do
                local v = children[i]
                
                if v.Name == "Handle.R" then
                    v:Destroy()
                elseif v:IsA("Model") then
                    v:Destroy()
                elseif v:IsA("BasePart") and v.Name ~= "Default" then
                    v:Destroy()
                end
            end
            
            mesh.Transparency = 0
        end
        
        knifeData[tool] = nil
    end

    local function applyKnife(character, tool, skin)
        local config = getgenv().KnifeSkins[skin]
        
        if not config then
            return
        end
        
        local humanoid = character:FindFirstChild("Humanoid")
        local rightHand = character:FindFirstChild("RightHand")
        
        if not humanoid or not rightHand then
            return
        end
        
        cleanKnife(tool)
        
        knifeData[tool] = {track=nil, welds={}}
        
        local data = knifeData[tool]
        local mesh = tool:FindFirstChild("Default")
        
        if not mesh then
            return
        end
        
        mesh.Transparency = 1
        
        local skinModules = ReplicatedStorage:FindFirstChild("SkinModules")
        
        if not skinModules then
            return
        end
        
        local knives = skinModules:FindFirstChild("Knives")
        
        if not knives then
            return
        end
        
        local skinModel = knives:FindFirstChild(skin)
        
        if not skinModel then
            return
        end
        
        local clone = skinModel:Clone()
        clone.Name = skin
        
        local handleR = Instance.new("Part")
        handleR.Name = "Handle.R"
        handleR.Transparency = 1
        handleR.CanCollide = false
        handleR.Anchored = false
        handleR.Size = Vector3.new(0.001, 0.001, 0.001)
        handleR.Massless = true
        handleR.Parent = mesh
        
        local motor = Instance.new("Motor6D")
        motor.Name = "Handle.R"
        motor.Part0 = rightHand
        motor.Part1 = handleR
        motor.Parent = handleR
        
        local offset = CFrame.new(config.positionOffset) * CFrame.Angles(
            math.rad(config.rotationOffset.X),
            math.rad(config.rotationOffset.Y),
            math.rad(config.rotationOffset.Z)
        )
        
        if clone:IsA("Model") then
            if not clone.PrimaryPart then
                local children = clone:GetChildren()
                
                for i = 1, #children do
                    local c = children[i]
                    
                    if c:IsA("BasePart") then
                        clone.PrimaryPart = c
                        break
                    end
                end
            end
            
            if clone.PrimaryPart then
                local descendants = clone:GetDescendants()
                
                for i = 1, #descendants do
                    local part = descendants[i]
                    
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                        part.Massless = true
                        part.Anchored = false
                        
                        local weld = Instance.new("Weld")
                        weld.Part0 = handleR
                        weld.Part1 = part
                        weld.C0 = offset
                        weld.C1 = part.CFrame:ToObjectSpace(clone.PrimaryPart.CFrame)
                        weld.Parent = part
                        
                        table.insert(data.welds, weld)
                    end
                end
            end
            
            clone.Parent = mesh
            
        elseif clone:IsA("BasePart") then
            clone.CanCollide = false
            clone.Massless = true
            clone.Anchored = false
            
            if clone:IsA("MeshPart") and config.textureId then
                clone.TextureID = config.textureId
            end
            
            if config.particle then
                local skinAssets = ReplicatedStorage:FindFirstChild("SkinAssets")
                
                if skinAssets then
                    local particleFolder = skinAssets:FindFirstChild("GunHandleParticle")
                    
                    if particleFolder then
                        local particleSource = particleFolder:FindFirstChild(skin)
                        
                        if particleSource then
                            local particleEmitter = particleSource:FindFirstChild("ParticleEmitter")
                            
                            if particleEmitter then
                                particleEmitter:Clone().Parent = clone
                            end
                        end
                    end
                end
            end
            
            clone.Parent = mesh
            
            local weld = Instance.new("Weld")
            weld.Part0 = handleR
            weld.Part1 = clone
            weld.C0 = offset
            weld.Parent = clone
            
            table.insert(data.welds, weld)
        end
        
        local animator = humanoid:FindFirstChildOfClass("Animator")
        
        if not animator then
            animator = Instance.new("Animator")
            animator.Parent = humanoid
        end
        
        if config.animationId and config.animationId ~= "" then
            local animation = Instance.new("Animation")
            animation.AnimationId = config.animationId
            
            local track = animator:LoadAnimation(animation)
            track.Looped = false
            track:Play()
            
            data.track = track
            
            animation:Destroy()
            
            track.Ended:Once(function()
                if data.track == track then
                    data.track = nil
                end
                
                track:Destroy()
            end)
        end
        
        if config.soundId and config.soundId ~= "" then
            if not getgenv()._currentKnifeSound or not getgenv()._currentKnifeSound.IsPlaying then
                local sound = Instance.new("Sound")
                sound.SoundId = config.soundId
                sound.Parent = workspace
                sound:Play()
                
                getgenv()._currentKnifeSound = sound
                
                sound.Ended:Connect(function()
                    sound:Destroy()
                    getgenv()._currentKnifeSound = nil
                end)
            end
        end
        
        tool:SetAttribute("CurrentKnifeSkin", skin)
    end

    local function setupTool(tool)
        if not tool:IsA("Tool") then
            return
        end
        
        if tool:GetAttribute("ScareSkinSetup") then
            return
        end
        
        tool:SetAttribute("ScareSkinSetup", true)
        
        tool.Equipped:Connect(function()
            local character = tool.Parent
            
            if character ~= LocalPlayer.Character then
                return
            end
            
            local skin = shared.ScareSkinData[tool.Name]
            
            if not skin or skin == "" then
                return
            end
            
            if tool.Name == "[Knife]" then
                applyKnife(character, tool, skin)
            elseif tool.Name == "[Bat]" then
                applyBat(tool, skin)
            else
                applyGun(tool, skin)
            end
        end)
        
        tool.Unequipped:Connect(function()
            if tool.Name == "[Knife]" then
                local data = knifeData[tool]
                
                if not data then
                    return
                end
                
                if data.welds then
                    for _, weld in ipairs(data.welds) do
                        if weld then
                            weld:Destroy()
                        end
                    end
                    
                    data.welds = {}
                end
                
                local mesh = tool:FindFirstChild("Default")
                
                if mesh then
                    local children = mesh:GetChildren()
                    
                    for i = 1, #children do
                        local v = children[i]
                        
                        if v.Name == "Handle.R" then
                            v:Destroy()
                        elseif v:IsA("Model") then
                            v:Destroy()
                        elseif v:IsA("MeshPart") and v.Name ~= "Default" then
                            v:Destroy()
                        end
                    end
                    
                    mesh.Transparency = 0
                end
            end
        end)
        
        if tool.Parent == LocalPlayer.Character then
            local skin = shared.ScareSkinData[tool.Name]
            
            if skin and skin ~= "" then
                if tool.Name == "[Knife]" then
                    task.spawn(function()
                        applyKnife(LocalPlayer.Character, tool, skin)
                    end)
                elseif tool.Name == "[Bat]" then
                    task.spawn(function()
                        applyBat(tool, skin)
                    end)
                else
                    task.spawn(function()
                        applyGun(tool, skin)
                    end)
                end
            end
        end
    end

    local function watchCharacter(character)
        if not character then
            return
        end
        
        local children = character:GetChildren()
        
        for i = 1, #children do
            local v = children[i]
            
            if v:IsA("Tool") then
                setupTool(v)
            end
        end
        
        character.ChildAdded:Connect(function(v)
            if v:IsA("Tool") then
