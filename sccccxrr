local AllPlayerFOVs = {}

local function UpdateAllPlayerFOVs()
    local FOVSettings = Settings['Silent Aimbot']['FOV']['Configuration']
    
    if not FOVSettings['Enabled'] or not FOVSettings['Visualize'] then
        for _, fovData in pairs(AllPlayerFOVs) do
            for i = 1, 4 do
                fovData.Lines[i].Visible = false
            end
        end
        return
    end
    
    if IsLocalPlayerKnocked() then
        for _, fovData in pairs(AllPlayerFOVs) do
            for i = 1, 4 do
                fovData.Lines[i].Visible = false
            end
        end
        return
    end
    
    if not state.manualAimActive then
        for _, fovData in pairs(AllPlayerFOVs) do
            for i = 1, 4 do
                fovData.Lines[i].Visible = false
            end
        end
        return
    end
    
    local FOVSize = FOVSettings['Size']
    local WhiteColor = Color3.fromRGB(255, 255, 255)
    local HoverColor = Settings['Silent Aimbot']['FOV']['Color'] or Color3.fromRGB(255, 0, 0)
    local EnableHoverColor = Settings['Silent Aimbot']['FOV']['Enable Hover Color'] or false
    
    local targetPlayer = CurrentTarget
    local playerList = Players:GetPlayers()
    
    for i = 1, #playerList do
        local Player = playerList[i]
        if Player == LocalPlayer then
            continue
        end
        
        if not IsPlayerValidForSilent(Player) then
            local fovData = AllPlayerFOVs[Player]
            if fovData then
                for j = 1, 4 do
                    fovData.Lines[j].Visible = false
                end
            end
            continue
        end
        
        if not Player.Character then
            local fovData = AllPlayerFOVs[Player]
            if fovData then
                for j = 1, 4 do
                    fovData.Lines[j].Visible = false
                end
            end
            continue
        end
        
        if targetPlayer and targetPlayer ~= Player then
            local fovData = AllPlayerFOVs[Player]
            if fovData then
                for j = 1, 4 do
                    fovData.Lines[j].Visible = false
                end
            end
            continue
        end
        
        local TargetRoot = Player.Character:FindFirstChild("HumanoidRootPart")
        if not TargetRoot then
            local fovData = AllPlayerFOVs[Player]
            if fovData then
                for j = 1, 4 do
                    fovData.Lines[j].Visible = false
                end
            end
            continue
        end
        
        local TopLeft, BottomRight = GetScreenBounds(TargetRoot, Vector3.new(FOVSize.X, FOVSize.Y, FOVSize.Z))
        
        local fovData = AllPlayerFOVs[Player]
        if not fovData then
            local lines = {}
            for j = 1, 4 do
                lines[j] = CreateDrawing("Line", {
                    Thickness = 0.1,
                    Color = WhiteColor,
                    Visible = false,
                    ZIndex = 5,
                })
            end
            fovData = { Lines = lines, TopLeft = TopLeft, BottomRight = BottomRight }
            AllPlayerFOVs[Player] = fovData
        end
        
        if TopLeft and BottomRight then
            local UseColor = WhiteColor
            if EnableHoverColor and targetPlayer == Player and state.manualAimActive and IsSilentAiming then
                UseColor = HoverColor
            end
            DrawFOVBox(fovData.Lines, TopLeft, BottomRight, UseColor)
            fovData.TopLeft = TopLeft
            fovData.BottomRight = BottomRight
        else
            for j = 1, 4 do
                fovData.Lines[j].Visible = false
            end
        end
    end
    
    for Player, fovData in pairs(AllPlayerFOVs) do
        if not Players:FindFirstChild(Player.Name) then
            for j = 1, 4 do
                fovData.Lines[j].Visible = false
            end
            AllPlayerFOVs[Player] = nil
        end
    end
end

local function UpdateTargetLine()
    local TargetLineSettings = Settings['Silent Aimbot']['Target Line']
    if TargetLineSettings['Enabled'] and state.manualAimActive and IsSilentAiming and CurrentTarget then
        local MouseLocation = UserInputService:GetMouseLocation()
        local MousePos = Vector2.new(MouseLocation.X, MouseLocation.Y)
        
        local TargetPart = GetSilentTargetPart(CurrentTarget)
        if TargetPart then
            local ScreenPos, OnScreen = Camera:WorldToViewportPoint(TargetPart.Position)
            if OnScreen then
                local TargetPos = Vector2.new(ScreenPos.X, ScreenPos.Y)
                TargetLine.From = MousePos
                TargetLine.To = TargetPos
                TargetLine.Visible = true
                TargetLine.Color = Settings['Visuals']['Colors']['Target Line'] or Color3.fromRGB(255, 0, 0)
                TargetLine.Thickness = TargetLineSettings['Thickness'] or 0.1
            else
                TargetLine.Visible = false
            end
        else
            TargetLine.Visible = false
        end
    else
        TargetLine.Visible = false
    end
end

