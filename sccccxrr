            if player ~= LocalPlayer and player.Character then
                local part = nil
                local isClosestPoint = IsSilentHitpartClosestPoint()
                if isClosestPoint then
                    part = GetClosestPart(player)
                else
                    part = player.Character:FindFirstChild(SilentCfg["Configuration"]["Target Zone"] or "HumanoidRootPart")
                end
                if part then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        local partPos = Vector2.new(screenPos.X, screenPos.Y)
                        local dist = (lastMousePos - partPos).Magnitude
                        
                        local radius = 1e9
                        if fovEnabled then
                            local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
                            local rootSize = rootPart and rootPart.Size.Y or 5
                            local scale = (rootSize * viewportY) / (screenPos.Z * 2) * 80 / camFOV
                            local halfW = math.min((fovSize.X or 10) * scale, viewportX * 2) / 2
                            local halfH = math.min((fovSize.Y or 10) * scale, viewportY * 2) / 2
                            radius = math.min(halfW, halfH)
                        end
                        
                        if dist < bestDist and dist <= radius then
                            bestPart, bestDist = part, dist
                        end
                    end
                end
            end
        end
        cachedTarget = bestPart
    end
    
    RunService.RenderStepped:Connect(UpdateTarget)
    
    local function ApplyPrediction(cf, offset)
        return cf * CFrame.new(offset.X, offset.Y, offset.Z)
    end
    
    local mt = getrawmetatable(game)
    if mt then
        setreadonly(mt, false)
        local oldIndex = mt.__index
        mt.__index = newcclosure(function(obj, prop)
            if obj:IsA("Mouse") and (prop == "Hit" or prop == "Target") then
                local target = cachedTarget
                if target then
                    local Settings = GetConfig()
                    local SilentCfg = Settings and Settings["Silent Aimbot"]
                    local prediction = { X = 0, Y = 0, Z = 0 }
                    local redir = SilentCfg and SilentCfg["Client Redirection"] or {}
                    local currentTool = (LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")) or nil
                    
                    if redir["Configuration"] and redir["Configuration"]["Enabled"] and currentTool then
                        local toolName = tostring(currentTool.Name)
                        local predCfg = redir["Configuration"]["Prediction"] or { X = 0.035, Y = 0.035, Z = 0.035 }
                        local weaponSpecific = redir["Configuration"]["Weapon Specific"] and redir["Configuration"]["Weapon Specific"]["Configuration"] or {}
                        local weaponName = string.lower(toolName)
                        if weaponSpecific["Rifle"] and (string.find(weaponName, "rifle") or string.find(weaponName, "ak") or string.find(weaponName, "m4")) then
                            prediction = predCfg
                        elseif weaponSpecific["Glock"] and string.find(weaponName, "glock") then
                            prediction = predCfg
                        elseif weaponSpecific["Revolver"] and string.find(weaponName, "revolver") then
                            prediction = predCfg
                        else
                            prediction = predCfg
                        end
                    else
                        local predCfg = SilentCfg and SilentCfg["Prediction"] and SilentCfg["Prediction"]["Configuration"] or {}
                        if predCfg and predCfg["Enabled"] then
                            prediction = { X = predCfg["X"] or 0, Y = predCfg["Y"] or 0, Z = predCfg["Z"] or 0 }
                        end
                    end
                    
                    local predMultiplier = Vector3.new(prediction.X or 0, prediction.Y or 0, prediction.Z or 0)
                    local offset = target.Velocity * predMultiplier
                    if prop == "Hit" then
                        return ApplyPrediction(target.CFrame, offset)
                    else
                        return target
                    end
                end
            end
            return oldIndex(obj, prop)
        end)
    end
    
    RunService.Heartbeat:Connect(function()
        local Settings = GetConfig()
        local SilentCfg = Settings and Settings["Silent Aimbot"]
        if not SilentCfg or not SilentCfg["Configuration"] or not SilentCfg["Configuration"]["Enabled"] then return end
        local target = cachedTarget
        local currentTool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if target and currentTool and currentTool:FindFirstChild("Activate") then
            currentTool:Activate()
        end
    end)
end

local function ValidateTarget(mode)
    local locked = (mode == "Silent" and State.SilentTargetLocked) or (mode == "Trigger" and State.TriggerTargetLocked)
    if not locked then return end
    
    local Target = State.Targets[mode]
    
    if Target then
        if IsTargetDead(Target) or not CheckConditionsExceptVisible(Target, mode) then
            State.Targets[mode] = nil
            if mode == "Silent" then
                State.SilentTargetLocked = false
            else
                State.TriggerTargetLocked = false
            end
            state.lastValidTarget = nil
            state.triggerLastValidTarget = nil
        elseif not CheckConditions(Target, mode) then
            if mode == "Silent" then
                state.lastValidTarget = Target
            else
                state.triggerLastValidTarget = Target
            end
            State.Targets[mode] = nil
        end
    end
    
    local isLocked = (mode == "Silent" and State.SilentTargetLocked) or (mode == "Trigger" and State.TriggerTargetLocked)
    local target = State.Targets[mode]
    
    if isLocked and not target then
        local cachedTarget = (mode == "Silent" and state.lastValidTarget) or (mode == "Trigger" and state.triggerLastValidTarget)
        if cachedTarget then
            if IsTargetDead(cachedTarget) or not CheckConditionsExceptVisible(cachedTarget, mode) then
                if mode == "Silent" then
                    State.SilentTargetLocked = false
                    state.lastValidTarget = nil
                else
                    State.TriggerTargetLocked = false
                    state.triggerLastValidTarget = nil
                end
            else
                local head = cachedTarget.Character and cachedTarget.Character:FindFirstChild("Head")
                if head and IsTargetVisible(head) then
                    State.Targets[mode] = cachedTarget
                    if mode == "Silent" then
                        state.lastValidTarget = nil
                    else
                        state.triggerLastValidTarget = nil
                    end
                end
            end
        end
    end
end

