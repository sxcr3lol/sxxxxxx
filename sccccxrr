local function FullCleanup()
    IsCleanedUp = true
    
    state.manualAimActive = false
    IsAiming = false
    IsSilentAiming = false
    ClearCurrentTarget()
    shared.CurrentTarget = nil
    shared.IsAiming = false
    shared.SilentAimTarget = nil
    ClientRedirect.TargetPosition = nil
    ClientRedirect.TargetPart = nil
    ClientRedirect.Enabled = false
    IsCursorInsideFOV = false
    
    for _, Connection in pairs(AllConnections) do
        pcall(function() Connection:Disconnect() end)
    end
    AllConnections = {}
    
    for _, Drawing in pairs(AllDrawingObjects) do
        pcall(function() Drawing:Remove() end)
    end
    AllDrawingObjects = {}
    
    for _, fovData in pairs(AllPlayerFOVs) do
        for i = 1, 4 do
            pcall(function() fovData.Lines[i]:Remove() end)
        end
    end
    AllPlayerFOVs = {}
    
    if GunHandler and OriginalGetAim then
        GunHandler.getAim = OriginalGetAim
    end
    
    if GunHandler and OriginalShoot then
        GunHandler.shoot = OriginalShoot
    end
    
    if shared.Scare then
        shared.Scare = nil
    end
end

