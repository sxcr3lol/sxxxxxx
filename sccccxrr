local function IsSameCrew(Player)
    local PlayerCrew = Player and Player:GetAttribute("CrewID")
    local ClientCrew = LocalPlayer:GetAttribute("CrewID")
    return PlayerCrew and ClientCrew and PlayerCrew == ClientCrew or false
end

local function IsPlayerKnocked(Player)
    local Object = Player and Player.Character
    local Body = Object and Object:FindFirstChild("BodyEffects")
    return Body and Body:FindFirstChild("K.O") and Body["K.O"].Value or false
end

local function IsLocalPlayerKnocked()
    return IsPlayerKnocked(LocalPlayer)
end

local function HasForcefieldOrInvis(Player)
    local Character = Player and Player.Character
    if not Character then return false end
    if Character:FindFirstChildOfClass("ForceField") then return true end
    if Character:FindFirstChild("FORCEFIELD") then return true end
    return false
end

local function IsInVehicle(Player)
    local Character = Player and Player.Character
    local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
    return Humanoid and Humanoid.Sit or false
end

local function IsTargetVisible(Part)
    if not Part then return false end
    local Origin = Camera.CFrame.Position
    local Direction = Part.Position - Origin
    local RayParams = RaycastParams.new()
    RayParams.FilterType = Enum.RaycastFilterType.Exclude
    RayParams.FilterDescendantsInstances = {LocalPlayer.Character}
    RayParams.IgnoreWater = true
    local Result = Workspace:Raycast(Origin, Direction, RayParams)
    if Result and Result.Instance then
        if Result.Instance:IsDescendantOf(Part.Parent) then
            return true
        end
        return false
    end
    return true
end

local function CheckConditions(Player, mode)
    local Settings = GetConfig()
    local Conditions = Settings and Settings['Configuration'] and Settings['Configuration']['Condition Specific'] and Settings['Configuration']['Condition Specific']['Configuration']
    if not Conditions then
        return true
    end
    
    local cond = Conditions[mode] or Conditions['Silent Aimbot']
    if not cond then
        return true
    end
    
    if cond['Crew'] and IsSameCrew(Player) then
        return false
    end
    if cond['Knocked'] and IsPlayerKnocked(Player) then
        return false
    end
    if cond['Self-Knocked'] and IsLocalPlayerKnocked() then
        return false
    end
    if cond['ForceField'] and HasForcefieldOrInvis(Player) then
        return false
    end
    if cond['Vehicle'] and IsInVehicle(Player) then
        return false
    end
    if cond['Visible'] then
        local Head = Player.Character and Player.Character:FindFirstChild("Head")
        if Head and not IsTargetVisible(Head) then
            return false
        end
    end
    
    return true
end

