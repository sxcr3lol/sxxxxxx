local function IsInTriggerFOV(Player)
    local Settings = GetConfig()
    if not Settings then return false end
    
    local MultiPartConfig = Settings['Trigger Bot'] and Settings['Trigger Bot']['Multi Part'] and Settings['Trigger Bot']['Multi Part']['Configuration']
    if MultiPartConfig and MultiPartConfig['Enabled'] then
        return IsInMultiPartZone(Player)
    end
    
    local Method = Settings['Trigger Bot']['Configuration']['FOV Method'] or 'FOV'
    
    if Method == 'Circle' then
        local CircleConfig = Settings['Trigger Bot']['Circle']['Configuration']
        if not CircleConfig or not CircleConfig['Enabled'] then
            return true
        end
        
        local Center = GetReferencePoint()
        local Radius = CircleConfig['Scale'] or 150
        
        if not Player or not Player.Character then
            return false
        end
        
        for _, Part in pairs(Player.Character:GetChildren()) do
            if Part:IsA("BasePart") then
                local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Part.Position)
                if OnScreen then
                    local Dist = math.sqrt((ScreenPos.X - Center.X)^2 + (ScreenPos.Y - Center.Y)^2)
                    if Dist <= Radius then
                        return true
                    end
                end
            end
        end
        
        return false
    end
    
    if Method == 'FOV' then
        local FOVConfig = Settings['Trigger Bot']['FOV']['Configuration']
        if not FOVConfig or not FOVConfig['Enabled'] then
            return true
        end
        local FOVSize = FOVConfig['Size'] or { X = 11, Y = 11, Z = 11 }
        local ScreenCenter = GetScreenCenter()
        return IsScreenPointInTargetBox(Player, ScreenCenter, FOVSize)
    else
        local HitPlayer, HitPart = GetMouseRaycastHit()
        return HitPlayer == Player
    end
end

local function GetTriggerCooldown()
    local Config = GetConfig()
    if not Config then return 0.01 end
    
    local TriggerCfg = Config["Trigger Bot"]
    if not TriggerCfg then return 0.01 end
    
    local FOVCfg = TriggerCfg["FOV"] or {}
    local CooldownValue = FOVCfg["Click Cooldown"]
    
    if type(CooldownValue) == "table" then
        local Character = LocalPlayer.Character
        if not Character then return 0.01 end
        
        local Tool = Character:FindFirstChildOfClass("Tool")
        if not Tool then return 0.01 end
        
        local WeaponName = Tool.Name
        
        for Key, Value in pairs(CooldownValue) do
            if Key == WeaponName then
                return Value
            end
        end
        
        return 0.01
    end
    
    return CooldownValue or 0.01
end

local function GetWeaponSwitchDelay()
    local Config = GetConfig()
    if not Config then return 0 end
    
    local TriggerCfg = Config["Trigger Bot"]
    if not TriggerCfg then return 0 end
    
    local WSCfg = TriggerCfg["Weapon Switching"] or {}
    local WSConfig = WSCfg["Configuration"] or {}
    
    if not WSConfig["Enabled"] then
        return 0
    end
    
    return WSConfig["Delay"] or 2.15
end

