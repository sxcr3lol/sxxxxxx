        end

        local PC = PanelColor
        local FC = FeatureColor
        local DotColor = Color3.new(0.35,0.35,0.35)
        
        PanelTitle.Text = string.format('<font color="rgb(%d,%d,%d)">Scare</font><font color="rgb(%d,%d,%d)">.</font><font color="rgb(%d,%d,%d)">%s</font>',
            math.floor(PC.R*255), math.floor(PC.G*255), math.floor(PC.B*255),
            math.floor(DotColor.R*255), math.floor(DotColor.G*255), math.floor(DotColor.B*255),
            math.floor(FC.R*255), math.floor(FC.G*255), math.floor(FC.B*255), AliasStr)
        PanelTitle.Size = 16
        PanelTitle.Position = Vector2.new(BaseX, BaseY)
        PanelTitle.Visible = true

        local OffsetY = BaseY + 20
        local LabelIdx = 0

        if StatusEnabled then
            if healthStatus ~= "" then
                LabelIdx = LabelIdx + 1
                local L = PanelLabels[LabelIdx]
                if L then
                    L.Text = string.format('(%s)', healthStatus)
                    L.Color = Color3.new(1,1,1)
                    L.Size = 14
                    L.Position = Vector2.new(BaseX, OffsetY)
                    L.Visible = true
                    OffsetY = OffsetY + 18
                end
            end

            LabelIdx = LabelIdx + 1
            local L = PanelLabels[LabelIdx]
            if L then
                L.Text = string.format('Silent Aim <font color="rgb(%d,%d,%d)">:</font> <font color="rgb(%d,%d,%d)">(%s)</font>',
                    math.floor(FC.R*255), math.floor(FC.G*255), math.floor(FC.B*255),
                    math.floor(CurrentColor.R*255), math.floor(CurrentColor.G*255), math.floor(CurrentColor.B*255),
                    silentName)
                L.Color = Color3.new(1,1,1)
                L.Size = 14
                L.Position = Vector2.new(BaseX, OffsetY)
                L.Visible = true
                OffsetY = OffsetY + 18
            end

            LabelIdx = LabelIdx + 1
            local L2 = PanelLabels[LabelIdx]
            if L2 then
                L2.Text = string.format('Trigger Bot <font color="rgb(%d,%d,%d)">:</font> <font color="rgb(%d,%d,%d)">(%s)</font>',
                    math.floor(FC.R*255), math.floor(FC.G*255), math.floor(FC.B*255),
                    math.floor(CurrentColor.R*255), math.floor(CurrentColor.G*255), math.floor(CurrentColor.B*255),
                    triggerName)
                L2.Color = Color3.new(1,1,1)
                L2.Size = 14
                L2.Position = Vector2.new(BaseX, OffsetY)
                L2.Visible = true
                OffsetY = OffsetY + 18
            end

            LabelIdx = LabelIdx + 1
            local L = PanelLabels[LabelIdx]
            if L then
                L.Text = string.format('WalkSpeed <font color="rgb(%d,%d,%d)">:</font> <font color="rgb(%d,%d,%d)">(%s)</font>',
                    math.floor(FC.R*255), math.floor(FC.G*255), math.floor(FC.B*255),
                    math.floor(CurrentColor.R*255), math.floor(CurrentColor.G*255), math.floor(CurrentColor.B*255),
                    walkSpeedStatus)
                L.Color = Color3.new(1,1,1)
                L.Size = 14
                L.Position = Vector2.new(BaseX, OffsetY)
                L.Visible = true
                OffsetY = OffsetY + 18
            end
        else
            LabelIdx = LabelIdx + 1
            local L = PanelLabels[LabelIdx]
            if L then
                L.Text = string.format('Silent Aim <font color="rgb(%d,%d,%d)">:</font> <font color="rgb(%d,%d,%d)">(%s)</font>',
                    math.floor(FC.R*255), math.floor(FC.G*255), math.floor(FC.B*255),
                    math.floor(CurrentColor.R*255), math.floor(CurrentColor.G*255), math.floor(CurrentColor.B*255),
                    silentName)
                L.Color = Color3.new(1,1,1)
                L.Size = 14
                L.Position = Vector2.new(BaseX, OffsetY)
                L.Visible = true
                OffsetY = OffsetY + 18
            end

            LabelIdx = LabelIdx + 1
