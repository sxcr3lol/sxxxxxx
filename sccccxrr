local function IsPlayerValid(Player, mode)
    if not Player or Player == LocalPlayer then
        return false
    end
    if not Player.Character then
        return false
    end
    local Humanoid = Player.Character:FindFirstChildOfClass("Humanoid")
    if not Humanoid or Humanoid.Health <= 0 then
        return false
    end
    if not Player.Character:FindFirstChild("Head") then
        return false
    end
    
    return CheckConditions(Player, mode)
end

local function GetClosestPlayerToCursor(MaxRange, mode)
    local MousePos = UserInputService:GetMouseLocation()
    local CamPos = Camera.CFrame.Position
    local Closest, BestDist = nil, math.huge
    for _, Plr in next, Players:GetPlayers() do
        if not IsPlayerValid(Plr, mode) then continue end
        local Root = Plr.Character and Plr.Character:FindFirstChild("HumanoidRootPart")
        if not Root then continue end
        if MaxRange and MaxRange < math.huge then
            local Dist = (CamPos - Root.Position).Magnitude
            if Dist > MaxRange then continue end
        end
        local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Root.Position)
        if not OnScreen or ScreenPos.Z <= 0 then continue end
        local Mag = (Vector2.new(ScreenPos.X, ScreenPos.Y) - MousePos).Magnitude
        if Mag < BestDist then
            BestDist = Mag
            Closest = Plr
        end
    end
    return Closest
end

local function GetScreenBounds(Model, SizeOffset)
    if not Model then
        return nil, nil
    end
    local HalfX = (Model.Size.X + SizeOffset.X) / 2
    local HalfY = (Model.Size.Y + SizeOffset.Y) / 2
    local HalfZ = (Model.Size.Z + SizeOffset.Z) / 2
    local CFrame = Model.CFrame
    local Corners = {
        Vector3.new( HalfX,  HalfY,  HalfZ), Vector3.new(-HalfX,  HalfY,  HalfZ),
        Vector3.new( HalfX, -HalfY,  HalfZ), Vector3.new(-HalfX, -HalfY,  HalfZ),
        Vector3.new( HalfX,  HalfY, -HalfZ), Vector3.new(-HalfX,  HalfY, -HalfZ),
        Vector3.new( HalfX, -HalfY, -HalfZ), Vector3.new(-HalfX, -HalfY, -HalfZ),
    }
    local MinX, MinY = math.huge, math.huge
    local MaxX, MaxY = -math.huge, -math.huge
    local HasVisiblePoint = false
    for _, Corner in pairs(Corners) do
        local ScreenPoint = Camera:WorldToViewportPoint(CFrame:PointToWorldSpace(Corner))
        if ScreenPoint.Z > 0 then
            HasVisiblePoint = true
            if ScreenPoint.X < MinX then MinX = ScreenPoint.X end
            if ScreenPoint.Y < MinY then MinY = ScreenPoint.Y end
            if ScreenPoint.X > MaxX then MaxX = ScreenPoint.X end
            if ScreenPoint.Y > MaxY then MaxY = ScreenPoint.Y end
        end
    end
    if not HasVisiblePoint then
        return nil, nil
    end
    return Vector2.new(MinX, MinY), Vector2.new(MaxX, MaxY)
end

local function GetScreenCenter()
    local ViewportSize = Camera.ViewportSize
    return Vector2.new(ViewportSize.X / 2, ViewportSize.Y / 2)
end

local function IsPointInBox(Point, TopLeft, BottomRight)
    return Point.X >= TopLeft.X and Point.X <= BottomRight.X and Point.Y >= TopLeft.Y and Point.Y <= BottomRight.Y
end

local function GetMouseRaycastHit()
    local MousePos = UserInputService:GetMouseLocation()
    local Ray = Camera:ViewportPointToRay(MousePos.X, MousePos.Y)
    local RayParams = RaycastParams.new()
    RayParams.FilterType = Enum.RaycastFilterType.Exclude
    if LocalPlayer and LocalPlayer.Character then
        RayParams.FilterDescendantsInstances = {LocalPlayer.Character}
    end
    RayParams.IgnoreWater = true
    local Result = Workspace:Raycast(Ray.Origin, Ray.Direction * 1000, RayParams)
    if Result and Result.Instance then
        local HitPart = Result.Instance
        local HitPlayer = nil
        for _, Plr in next, Players:GetPlayers() do
            if Plr.Character and HitPart:IsDescendantOf(Plr.Character) then
                HitPlayer = Plr
                break
            end
        end
        return HitPlayer, HitPart
    end
    return nil, nil
end

local function IsScreenPointInTargetBox(Player, ScreenPoint, FOVSize)
    if not Player.Character then
        return false
    end
    local TargetRoot = Player.Character:FindFirstChild("HumanoidRootPart")
    if not TargetRoot then
        return false
    end
    local TopLeft, BottomRight = GetScreenBounds(TargetRoot, Vector3.new(FOVSize.X, FOVSize.Y, FOVSize.Z))
    if not TopLeft or not BottomRight then
        return false
    end
    return ScreenPoint.X >= TopLeft.X and ScreenPoint.X <= BottomRight.X and ScreenPoint.Y >= TopLeft.Y and ScreenPoint.Y <= BottomRight.Y
end

local function GetReferencePoint()
    local Settings = GetConfig()
    local MouseLock = Settings and Settings['Trigger Bot'] and Settings['Trigger Bot']['Configuration'] and Settings['Trigger Bot']['Configuration']['Mouse Lock']
    if MouseLock then
        local MouseLocation = UserInputService:GetMouseLocation()
        return Vector2.new(MouseLocation.X, MouseLocation.Y)
    else
        return GetScreenCenter()
    end
end

local function GetMultiPartTargetZones()
    local Settings = GetConfig()
    if not Settings then return nil end
    
    local MultiPartConfig = Settings['Trigger Bot'] and Settings['Trigger Bot']['Multi Part'] and Settings['Trigger Bot']['Multi Part']['Configuration']
    if not MultiPartConfig or not MultiPartConfig['Enabled'] then
        return nil
    end
    
    local TargetZoneStr = MultiPartConfig['Target Zone']
    if not TargetZoneStr or TargetZoneStr == '' then
        return nil
    end
    
    if TargetZoneStr == "Nearest Part" then
        return INTERNAL_HITPARTS
    end
    
    local Zones = {}
    for Zone in string.gmatch(TargetZoneStr, '([^,]+)') do
        local Trimmed = Zone:match("^%s*(.-)%s*$")
        if Trimmed ~= '' then
            table.insert(Zones, Trimmed)
        end
    end
    
    if #Zones == 0 then
        return nil
    end
    
    return Zones
end

local function IsInMultiPartZone(Player)
    local Settings = GetConfig()
    if not Settings then return false end
    
    local MultiPartConfig = Settings['Trigger Bot'] and Settings['Trigger Bot']['Multi Part'] and Settings['Trigger Bot']['Multi Part']['Configuration']
    if not MultiPartConfig or not MultiPartConfig['Enabled'] then
        return true
    end
    
    local Zones = GetMultiPartTargetZones()
    if not Zones then
        return true
    end
    
    if not Player or not Player.Character then
        return false
    end
    
    local RefPoint = GetReferencePoint()
    
    for _, ZoneName in pairs(Zones) do
        local Part = Player.Character:FindFirstChild(ZoneName)
        if Part and Part:IsA("BasePart") then
            local TopLeft, BottomRight = GetScreenBounds(Part, Vector3.new(0, 0, 0))
            if TopLeft and BottomRight then
                if IsPointInBox(RefPoint, TopLeft, BottomRight) then
                    return true
                end
            end
        end
    end
    
    return false
end

