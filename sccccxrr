local function IsHoldingKnife()
    local WeaponName = GetCurrentWeaponNameMovement()
    if not WeaponName then
        return false
    end
    local KnifeKeywords = {"knife", "Knife", "KNIFE", "Dagger", "Blade", "Sword"}
