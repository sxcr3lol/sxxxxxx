local function IsHoldingKnife()
    local WeaponName = GetCurrentWeaponNameMovement()
    if not WeaponName then
        return false
    end
    local KnifeKeywords = {"knife", "Knife", "KNIFE", "Dagger", "Blade", "Sword"}
    for _, Keyword in pairs(KnifeKeywords) do
        if WeaponName:find(Keyword) then
            return true
        end
    end
    return false
end

local function IsPlayerReloading()
    local Character = LocalPlayer.Character
    if not Character then
        return false
    end
    local Tool = Character:FindFirstChildOfClass("Tool")
    if not Tool then
        return false
    end
    local WeaponHandler = Tool:FindFirstChild("WeaponHandler")
    if WeaponHandler then
        local Reloading = WeaponHandler:FindFirstChild("Reloading")
        if Reloading then
            return Reloading.Value == true
        end
    end
    local Ammo = Tool:FindFirstChild("Ammo")
    local MaxAmmo = Tool:FindFirstChild("MaxAmmo")
    if Ammo and MaxAmmo then
        if Ammo.Value < MaxAmmo.Value then
            return true
        end
    end
    return false
end

local function IsPlayerShooting()
    local Character = LocalPlayer.Character
    if not Character then
        return false
    end
    local Tool = Character:FindFirstChildOfClass("Tool")
    if not Tool then
        return false
    end
    local CurrentTime = tick()
    local WeaponHandler = Tool:FindFirstChild("WeaponHandler")
    if WeaponHandler then
        local Shooting = WeaponHandler:FindFirstChild("Shooting")
        if Shooting then
            if Shooting.Value == true then
                state.LastShootTime = CurrentTime
                return true
            end
        end
    end
    if CurrentTime - state.LastShootTime < 0.1 then
        return true
    end
    return false
end

local function GetCurrentState()
    local WeaponName = GetCurrentWeaponNameMovement()
    if WeaponName then
        local MovementCfg = shared.Scare['Movement Modifications']['Configuration']
        if MovementCfg and MovementCfg[WeaponName] and MovementCfg[WeaponName]['Multiplier'] then
            return WeaponName
        end
    end
    if IsHoldingKnife() then
        return "Knife"
    end
    if IsPlayerShooting() then
        return "Shooting"
    end
    if IsPlayerReloading() then
        return "Reloading"
    end
    local Status = GetHealthStatus()
    if Status == "Low Health" then
        return "Low Health"
    end
    return "Normal"
end

local function UpdateSpeed()
    if not state.PlayerHumanoid then
        return
    end
    
    local ScareConfig = shared.Scare
    if not ScareConfig then
        return
    end
    
    local MovementSettings = ScareConfig['Movement Modifications']
    if not MovementSettings then
        return
    end
    
    local MovementCfg = MovementSettings['Configuration']
    if not MovementCfg then
        return
    end
    
    if state.SpeedModEnabled and MovementCfg['Enabled'] then
        local CurrentState = GetCurrentState()
        local Multiplier = 1
        local StateConfig = MovementCfg[CurrentState]
        if StateConfig and StateConfig['Multiplier'] then
            Multiplier = type(StateConfig['Multiplier']) == 'table' and StateConfig['Multiplier'][1] or StateConfig['Multiplier']
        elseif CurrentState == "Normal" then
            local NormalCfg = MovementCfg['Normal']
            if NormalCfg then
                Multiplier = type(NormalCfg['Multiplier']) == 'table' and NormalCfg['Multiplier'][1] or NormalCfg['Multiplier']
            end
        elseif CurrentState == "Knife" then
            local KnifeCfg = MovementCfg['Knife']
            if KnifeCfg then
                Multiplier = type(KnifeCfg['Multiplier']) == 'table' and KnifeCfg['Multiplier'][1] or KnifeCfg['Multiplier']
            end
        elseif CurrentState == "Shooting" then
            local ShootingCfg = MovementCfg['Shooting']
            if ShootingCfg then
                Multiplier = type(ShootingCfg['Multiplier']) == 'table' and ShootingCfg['Multiplier'][1] or ShootingCfg['Multiplier']
            end
        elseif CurrentState == "Reloading" then
            local ReloadingCfg = MovementCfg['Reloading']
            if ReloadingCfg then
                Multiplier = type(ReloadingCfg['Multiplier']) == 'table' and ReloadingCfg['Multiplier'][1] or ReloadingCfg['Multiplier']
            end
        elseif CurrentState == "Low Health" then
            local LowHealthCfg = MovementCfg['Low Health']
            if LowHealthCfg then
                Multiplier = type(LowHealthCfg['Multiplier']) == 'table' and LowHealthCfg['Multiplier'][1] or LowHealthCfg['Multiplier']
            end
        end
        
        local NewSpeed = 16 * Multiplier
        if state.PlayerHumanoid.WalkSpeed ~= NewSpeed then
            state.PlayerHumanoid.WalkSpeed = NewSpeed
        end
    else
        if state.PlayerHumanoid.WalkSpeed ~= 16 and state.PlayerHumanoid.WalkSpeed ~= 0 then
            state.PlayerHumanoid.WalkSpeed = 16
        end
    end
end

local function SetupPanicGround(Character)
    if not Character then return end
    local RootPart = Character:FindFirstChild('HumanoidRootPart')
    if not RootPart then return end
    if state.PanicGroundConnection then
        pcall(function() state.PanicGroundConnection:Disconnect() end)
        state.PanicGroundConnection = nil
    end
    local JumpCfg = shared.Scare['Jump Modifications']['Configuration']
    local PanicCfg = JumpCfg['Panic Ground']
    if not PanicCfg or not PanicCfg['Enabled'] then return end
    local PanicKey = PanicCfg['Keybind'] or 'G'
    local PanicKeyCode = Enum.KeyCode[PanicKey]
    local PANIC_DISTANCE = 1000
    
    local function GetNearestGroundBelow()
        local RaycastParams = RaycastParams.new()
        RaycastParams.FilterDescendantsInstances = {Character}
        RaycastParams.FilterType = Enum.RaycastFilterType.Blacklist
        local Result = Workspace:Raycast(RootPart.Position, Vector3.new(0, -PANIC_DISTANCE, 0), RaycastParams)
        if Result then
            return Result.Position.Y + 3
        end
        return RootPart.Position.Y - 10
    end
    
    local JumpRequestConnection = UserInputService.JumpRequest:Connect(function()
        if state.PanicActive then
            return
        end
    end)
    table.insert(NoJumpCooldownConnections, JumpRequestConnection)
    
    state.PanicGroundConnection = UserInputService.InputBegan:Connect(function(input, GameProcessed)
        if GameProcessed then return end
        if PanicKeyCode and input.KeyCode == PanicKeyCode then
            state.PanicActive = true
            state.VelocityLockEnabled = false
            local GroundY = GetNearestGroundBelow()
            local NewPosition = Vector3.new(RootPart.Position.X, GroundY, RootPart.Position.Z)
            RootPart.CFrame = CFrame.new(NewPosition)
            RootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            RootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            if state.PlayerHumanoid then
                state.PlayerHumanoid:ChangeState(Enum.HumanoidStateType.Landed)
            end
            task.wait(0.1)
            state.PanicActive = false
            state.VelocityLockEnabled = true
        end
    end)
    table.insert(AllConnections, state.PanicGroundConnection)
end

