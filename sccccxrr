        for _, Drawing in pairs(MultiPartDrawings or {}) do
            if type(Drawing) == "table" then
                for _, Line in pairs(Drawing or {}) do
                    if Line then
                        Line.Visible = false
                    end
                end
            end
        end
        for _, Drawing in pairs(MultiPartOutlineDrawings or {}) do
            if type(Drawing) == "table" then
                for _, Line in pairs(Drawing or {}) do
                    if Line then
                        Line.Visible = false
                    end
                end
            end
        end
        return
    end
    
    local Zones = GetMultiPartTargetZones()
    if not Zones then
        for _, Drawing in pairs(MultiPartDrawings or {}) do
            if type(Drawing) == "table" then
                for _, Line in pairs(Drawing or {}) do
                    if Line then
                        Line.Visible = false
                    end
                end
            end
        end
        for _, Drawing in pairs(MultiPartOutlineDrawings or {}) do
            if type(Drawing) == "table" then
                for _, Line in pairs(Drawing or {}) do
                    if Line then
                        Line.Visible = false
                    end
                end
            end
        end
        return
    end
    
    for _, ZoneName in pairs(Zones) do
        local Part = Target.Character:FindFirstChild(ZoneName)
        if Part and Part:IsA("BasePart") then
            if not MultiPartDrawings[ZoneName] then
                MultiPartDrawings[ZoneName] = {}
                MultiPartOutlineDrawings[ZoneName] = {}
                for i = 1, 4 do
                    MultiPartOutlineDrawings[ZoneName][i] = Drawing.new("Line")
                    MultiPartOutlineDrawings[ZoneName][i].Thickness = 3
                    MultiPartOutlineDrawings[ZoneName][i].Color = Color3.new(0, 0, 0)
                    MultiPartOutlineDrawings[ZoneName][i].Visible = false
                    MultiPartOutlineDrawings[ZoneName][i].ZIndex = 4
                    MultiPartDrawings[ZoneName][i] = Drawing.new("Line")
                    MultiPartDrawings[ZoneName][i].Thickness = 1
                    MultiPartDrawings[ZoneName][i].Color = PartColors[ZoneName] or Color3.new(1, 1, 1)
                    MultiPartDrawings[ZoneName][i].Visible = false
                    MultiPartDrawings[ZoneName][i].ZIndex = 5
                end
            end
            
            local TopLeft, BottomRight = GetScreenBounds(Part, Vector3.new(0, 0, 0))
            if TopLeft and BottomRight then
                local Lines = MultiPartDrawings[ZoneName]
                local Outlines = MultiPartOutlineDrawings[ZoneName]
                local Color = PartColors[ZoneName] or Color3.new(1, 1, 1)
                
                Lines[1].From = TopLeft
                Lines[1].To = Vector2.new(BottomRight.X, TopLeft.Y)
                Lines[2].From = Vector2.new(TopLeft.X, BottomRight.Y)
                Lines[2].To = BottomRight
                Lines[3].From = TopLeft
                Lines[3].To = Vector2.new(TopLeft.X, BottomRight.Y)
                Lines[4].From = Vector2.new(BottomRight.X, TopLeft.Y)
                Lines[4].To = BottomRight
                
                Outlines[1].From = Vector2.new(TopLeft.X - 1, TopLeft.Y - 1)
                Outlines[1].To = Vector2.new(BottomRight.X + 1, TopLeft.Y - 1)
                Outlines[2].From = Vector2.new(TopLeft.X - 1, BottomRight.Y + 1)
                Outlines[2].To = Vector2.new(BottomRight.X + 1, BottomRight.Y + 1)
                Outlines[3].From = Vector2.new(TopLeft.X - 1, TopLeft.Y - 1)
                Outlines[3].To = Vector2.new(TopLeft.X - 1, BottomRight.Y + 1)
                Outlines[4].From = Vector2.new(BottomRight.X + 1, TopLeft.Y - 1)
                Outlines[4].To = Vector2.new(BottomRight.X + 1, BottomRight.Y + 1)
                
                for i = 1, 4 do
                    Lines[i].Color = Color
                    Lines[i].Visible = true
                    Outlines[i].Color = Color3.new(0, 0, 0)
                    Outlines[i].Visible = true
                end
            else
                for i = 1, 4 do
                    if MultiPartDrawings[ZoneName] and MultiPartDrawings[ZoneName][i] then
                        MultiPartDrawings[ZoneName][i].Visible = false
                    end
                    if MultiPartOutlineDrawings[ZoneName] and MultiPartOutlineDrawings[ZoneName][i] then
                        MultiPartOutlineDrawings[ZoneName][i].Visible = false
                    end
                end
            end
        end
    end
end

