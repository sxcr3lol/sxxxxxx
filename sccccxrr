local function SetupPanicGround(Character)
    if not Character then return end
    local RootPart = Character:FindFirstChild('HumanoidRootPart')
    if not RootPart then return end
    if state.PanicGroundConnection then
        pcall(function() state.PanicGroundConnection:Disconnect() end)
        state.PanicGroundConnection = nil
    end
    local JumpCfg = shared.Scare['Jump Modifications']['Configuration']
    local PanicCfg = JumpCfg['Panic Ground']
    if not PanicCfg or not PanicCfg['Enabled'] then return end
    local PanicKey = PanicCfg['Keybind'] or 'G'
    local PanicKeyCode = Enum.KeyCode[PanicKey]
    local PANIC_DISTANCE = 1000
    
    local function GetNearestGroundBelow()
        local RaycastParams = RaycastParams.new()
        RaycastParams.FilterDescendantsInstances = {Character}
        RaycastParams.FilterType = Enum.RaycastFilterType.Blacklist
        local Result = Workspace:Raycast(RootPart.Position, Vector3.new(0, -PANIC_DISTANCE, 0), RaycastParams)
        if Result then
            return Result.Position.Y + 3
        end
        return RootPart.Position.Y - 10
    end
    
    local JumpRequestConnection = UserInputService.JumpRequest:Connect(function()
        if state.PanicActive then
            return
        end
    end)
    table.insert(NoJumpCooldownConnections, JumpRequestConnection)
    
    state.PanicGroundConnection = UserInputService.InputBegan:Connect(function(input, GameProcessed)
        if GameProcessed then return end
        if PanicKeyCode and input.KeyCode == PanicKeyCode then
            state.PanicActive = true
            state.VelocityLockEnabled = false
            local GroundY = GetNearestGroundBelow()
            local NewPosition = Vector3.new(RootPart.Position.X, GroundY, RootPart.Position.Z)
            RootPart.CFrame = CFrame.new(NewPosition)
            RootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            RootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            local Humanoid = Character:FindFirstChildOfClass("Humanoid")
            if Humanoid then
                Humanoid:ChangeState(Enum.HumanoidStateType.Landed)
            end
            task.wait(0.1)
            state.PanicActive = false
            state.VelocityLockEnabled = true
        end
    end)
    table.insert(AllConnections, state.PanicGroundConnection)
end

local function AntiFall(Character)
