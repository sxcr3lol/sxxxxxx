local INTERNAL_HITPARTS = {
    "Head","UpperTorso","HumanoidRootPart","LowerTorso",
    "LeftHand","RightHand","LeftLowerArm","RightLowerArm",
    "LeftUpperArm","RightUpperArm","LeftFoot","RightFoot",
    "LeftLowerLeg","RightLowerLeg","LeftUpperLeg","RightUpperLeg"
}

local function basicpoint(part, rayOrigin, rayDirection)
    if not part then return nil end
    
    local check = RaycastParams.new()
    check.FilterType = Enum.RaycastFilterType.Whitelist
    check.FilterDescendantsInstances = {part}
    check.IgnoreWater = true
    
    local ray = Workspace:Raycast(rayOrigin, rayDirection * 1000, check)
    if ray and ray.Instance == part then
        return ray.Position
    end
    
    return nil
end

local function getClosestPoint(character, cfgOverride)
    if not (character and character.Parent) then 
        return nil
    end
    
    local mousePos = UserInputService:GetMouseLocation()
    local mouseX, mouseY = mousePos.X, mousePos.Y
    local cam = Camera
    
    local ray = cam:ViewportPointToRay(mouseX, mouseY)
    if not ray then
        return nil
    end

    local cfg = cfgOverride or Settings['Silent Aimbot']['Configuration']['Point Configuration']
    if not cfg then
        return nil
    end

    local mode = cfg['Method'] or "Advanced"
    local scale = cfg['Point Scaling'] or 9.0
    local density = math.clamp(math.floor(scale), 2, 12)

    local allParts = {}
    for _, name in pairs(INTERNAL_HITPARTS) do
        local part = character:FindFirstChild(name)
        if part and part:IsA("BasePart") then
            table.insert(allParts, part)
        end
    end

    if #allParts == 0 then
        return nil
    end

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Whitelist
    rayParams.FilterDescendantsInstances = allParts
    rayParams.IgnoreWater = true
    
    local directHit = Workspace:Raycast(ray.Origin, ray.Direction * 1000, rayParams)
    if directHit then
        return { 
            Part = directHit.Instance, 
            Position = directHit.Position 
        }
    end

    if mode == "Basic" then
        local bestDist = 1e9
        local bestResult = nil
        
        for _, part in pairs(allParts) do
            local hitPoint = basicpoint(part, ray.Origin, ray.Direction)
            if hitPoint then
                local s = cam:WorldToViewportPoint(hitPoint)
                if s.Z > 0 then
                    local dist = (s.X - mouseX) * (s.X - mouseX) + (s.Y - mouseY) * (s.Y - mouseY)
                    if dist < bestDist then
                        bestDist = dist
                        bestResult = { Part = part, Position = hitPoint }
                    end
                end
            end
        end
        
        if bestResult then return bestResult end
    else
        local bestDist = 1e9
        local bestResult = nil
        
        local STEP = 1 / (density - 1)
        local STEP_OFFSETS = {}
        for j = 0, density - 1 do 
            STEP_OFFSETS[j + 1] = j * STEP 
        end

        for _, part in pairs(allParts) do
            local size = part.Size
            local half = size * 0.5
            local cframe = part.CFrame

            for z = 1, density do
                local clampedZ = -half.Z + STEP_OFFSETS[z] * size.Z
                
                for y = 1, density do
                    local clampedY = -half.Y + STEP_OFFSETS[y] * size.Y
                    
                    for x = 1, density do
                        local clampedX = -half.X + STEP_OFFSETS[x] * size.X
                        
                        local worldPos = cframe:PointToWorldSpace(Vector3.new(clampedX, clampedY, clampedZ))
                        
                        local s = cam:WorldToViewportPoint(worldPos)
                        if s.Z > 0 then
                            local dist = (s.X - mouseX) * (s.X - mouseX) + (s.Y - mouseY) * (s.Y - mouseY)
                            if dist < bestDist then
                                bestDist = dist
                                bestResult = { Part = part, Position = worldPos }
                            end
                        end
                    end
                end
            end
        end
        
        if bestResult then return bestResult end
    end

    local root = character:FindFirstChild("HumanoidRootPart")
    if root then
        return { Part = root, Position = root.Position }
    end
    
    return nil
end

local function IsPlayerValidForSilent(Player)
    if not Player or Player == LocalPlayer then
        return false
    end
    if not Player.Character then
        return false
    end
    local Humanoid = Player.Character:FindFirstChildOfClass("Humanoid")
    if not Humanoid or Humanoid.Health <= 0 then
        return false
    end
    if not Player.Character:FindFirstChild("Head") then
        return false
    end
    
    return CheckConditions(Player)
end

local function IsInSilentFOV(Player)
    local FOVSettings = Settings['Silent Aimbot']['FOV']['Configuration']
    if not FOVSettings['Enabled'] then
        return true
    end
    
    local FOVSize = FOVSettings['Size']
    local MouseLocation = UserInputService:GetMouseLocation()
    local MousePos = Vector2.new(MouseLocation.X, MouseLocation.Y)
    
    return IsScreenPointInTargetBox(Player, MousePos, FOVSize)
end

local function GetSilentTargetPart(Player)
    local Character = Player.Character
    if not Character then
        return nil
    end
    
    local HitPartMode = Settings['Silent Aimbot']['Configuration']['Target Zone']
    
    if IsSilentHitpartClosestPoint() then
        local result = getClosestPoint(Character)
        if result then
            return result.Part, result.Position
        end
        return nil
    elseif HitPartMode == 'Nearest Part' then
        local ScreenCenter = GetScreenCenter()
        local ClosestDistance = math.huge
        local ClosestPart = nil
        
        for _, HitboxName in pairs(INTERNAL_HITPARTS) do
            local Part = Character:FindFirstChild(HitboxName)
            if Part and Part:IsA("BasePart") then
                local ScreenPos, IsOnScreen = Camera:WorldToViewportPoint(Part.Position)
                if IsOnScreen then
                    local Distance = (ScreenPos.X - ScreenCenter.X) * (ScreenPos.X - ScreenCenter.X) + (ScreenPos.Y - ScreenCenter.Y) * (ScreenPos.Y - ScreenCenter.Y)
                    if Distance < ClosestDistance then
                        ClosestDistance = Distance
                        ClosestPart = Part
                    end
                end
            end
        end
        return ClosestPart
    else
        local Part = Character:FindFirstChild(HitPartMode)
        if Part and Part:IsA("BasePart") then
            return Part
        end
    end
    return nil
end

local function GetNearestPlayer(FOV)
    local Distance = math.huge
    local Target = nil
    local playerList = Players:GetPlayers()
    local mousePos = UserInputService:GetMouseLocation()
    local mouseVec = Vector2.new(mousePos.X, mousePos.Y)

    for i = 1, #playerList do
        local Player = playerList[i]
        if Player == LocalPlayer then
            continue
        end
        if not IsPlayerValidForSilent(Player) then
            continue
        end
        if not IsInSilentFOV(Player) then
            continue
        end

        local Head = Player.Character and Player.Character:FindFirstChild("Head")
        if not Head then
            continue
        end

        local Position, OnScreen = Camera:WorldToViewportPoint(Head.Position)
        if not OnScreen then
            continue
        end

        local dx = Position.X - mouseVec.X
        local dy = Position.Y - mouseVec.Y
        local Magnitude = dx * dx + dy * dy

        if Magnitude <= Distance and Magnitude <= FOV * FOV then
            Distance = Magnitude
            Target = Player
        end
    end
    return Target
end

local function IsCursorInsideTargetFOV(Player)
    if not Player or not Player.Character then
        return false
    end
    local FOVSettings = Settings['Silent Aimbot']['FOV']['Configuration']
    if not FOVSettings['Enabled'] then
        return true
    end
    local FOVSize = FOVSettings['Size']
    local MouseLocation = UserInputService:GetMouseLocation()
    local MousePos = Vector2.new(MouseLocation.X, MouseLocation.Y)
    return IsScreenPointInTargetBox(Player, MousePos, FOVSize)
end

GunHandler.getAim = function(origin, range)
    if not Settings['Silent Aimbot']['Configuration']['Enabled'] then
        return OriginalGetAim(origin, range)
    end
    if not IsSilentAiming then
        return OriginalGetAim(origin, range)
    end
    if IsLocalPlayerKnocked() then
        return OriginalGetAim(origin, range)
    end
    if not IsWeaponEnabled('Silent Aimbot') then
        return OriginalGetAim(origin, range)
    end
    if not IsCursorInsideFOV then
        return OriginalGetAim(origin, range)
    end
    
    if not CurrentTarget or not CurrentTarget.Character then
        return OriginalGetAim(origin, range)
    end
    
    if not IsTargetStillValid() then
        ClearCurrentTarget()
        return OriginalGetAim(origin, range)
    end
    
    local TargetPart, TargetPosition = GetSilentTargetPart(CurrentTarget)
    if not TargetPart then
        return OriginalGetAim(origin, range)
    end
    
    local FOVSettings = Settings['Silent Aimbot']['FOV']['Configuration']
    if FOVSettings['Enabled'] then
        local FOVSize = FOVSettings['Size']
        local MouseLocation = UserInputService:GetMouseLocation()
        local MousePos = Vector2.new(MouseLocation.X, MouseLocation.Y)
        if not IsScreenPointInTargetBox(CurrentTarget, MousePos, FOVSize) then
            return OriginalGetAim(origin, range)
        end
    end
    
    if not TargetPosition then
        TargetPosition = TargetPart.Position
    end
    
    local RootPart = CurrentTarget.Character:FindFirstChild("HumanoidRootPart")
    
    if RootPart and CurrentPing > 0 then
        local Velocity = RootPart.AssemblyLinearVelocity
        local PingCompensation = CurrentPing / 100
        if PingCompensation < 0.1 then PingCompensation = 0.1 end
        if PingCompensation > 0.5 then PingCompensation = 0.5 end
        
        TargetPosition = TargetPosition + Vector3.new(
            Velocity.X * PingCompensation,
            Velocity.Y * PingCompensation,
            Velocity.Z * PingCompensation
        )
    end
    
    local Prediction = Settings['Silent Aimbot']['Prediction']['Configuration']
    if Prediction and Prediction['Enabled'] and (Prediction.X ~= 0 or Prediction.Y ~= 0 or Prediction.Z ~= 0) and RootPart then
        local Velocity = RootPart.AssemblyLinearVelocity
        TargetPosition = TargetPosition + Vector3.new(
            Velocity.X * Prediction.X, 
            Velocity.Y * Prediction.Y, 
            Velocity.Z * Prediction.Z
        )
    end
    
    local clientPrediction = Settings['Silent Aimbot']['Client Redirection']['Configuration']['Prediction']
    if clientPrediction and IsClientRedirectEnabled() then
        local Velocity = RootPart.AssemblyLinearVelocity
        TargetPosition = TargetPosition + Vector3.new(
            Velocity.X * clientPrediction.X,
            Velocity.Y * clientPrediction.Y,
            Velocity.Z * clientPrediction.Z
        )
    end
    
    ClientRedirect.TargetPosition = TargetPosition
    ClientRedirect.TargetPart = TargetPart
    ClientRedirect.Enabled = IsClientRedirectEnabled()
    
    local dir = (TargetPosition - origin)
    local mag = dir.Magnitude
    local maxRange = range or 200
    return dir.Unit, mag < maxRange and mag or maxRange
end

if GunHandler and GunHandler.shoot then
    GunHandler.shoot = function(args)
        if checkcaller() then 
            if OriginalShoot then
                return OriginalShoot(args)
            end
            return args
        end

        local redirectEnabled = Settings['Silent Aimbot']['Configuration']['Enabled'] and 
                                IsSilentAiming and 
                                ClientRedirect.Enabled and 
                                ClientRedirect.TargetPosition and 
                                ClientRedirect.TargetPart and
                                IsWeaponEnabled('Silent Aimbot') and
                                IsClientRedirectEnabled() and
                                IsCursorInsideFOV

        if not redirectEnabled then
            if OriginalShoot then
                return OriginalShoot(args)
            end
            return args
        end

        local muzzle = args.ForcedOrigin or (args.Handle and args.Handle:FindFirstChild("Muzzle") and args.Handle.Muzzle.WorldPosition)
        local origin = muzzle or Camera.CFrame.Position
        local targetPos = ClientRedirect.TargetPosition
        local targetPart = ClientRedirect.TargetPart

        local _origAimPos = args.AimPosition

        local targetVec = targetPos - origin
        local targetMag = targetVec.Magnitude

        if targetMag > 0.01 then
            local targetDir = targetVec / targetMag

            local pelletDir
            if args.AimPosition then
                local pv = args.AimPosition - origin
                local pm = pv.Magnitude
                pelletDir = pm > 0.01 and pv / pm or targetDir
            else
                pelletDir = targetDir
            end

            local spreadOffset = pelletDir - targetDir

            local crosshairVec = GetCrosshairPos() - origin
            local crosshairMag = crosshairVec.Magnitude
            if crosshairMag > 0.01 then
                local crosshairDir = crosshairVec / crosshairMag
                local visualDir = crosshairDir + spreadOffset
                local visualMag = visualDir.Magnitude
                if visualMag > 0.001 then
                    args.AimPosition = origin + (visualDir / visualMag) * targetMag
                else
                    args.AimPosition = GetCrosshairPos()
                end
            else
                args.AimPosition = GetCrosshairPos()
            end
        else
            args.AimPosition = GetCrosshairPos()
        end

        local results
        if OriginalShoot then
            results = { OriginalShoot(args) }
        else
            results = { args }
        end
        
        args.AimPosition = _origAimPos

        if results[1] then results[1] = targetPos end
        if results[2] and targetPart then results[2] = targetPart end
        if results[3] and muzzle then
            results[3] = (targetPos - muzzle).Unit
        end

        return unpack(results)
    end
end

