            end
        end

        for i = LabelIdx + 1, #PanelLabels do
            if PanelLabels[i].Visible then PanelLabels[i].Visible = false end
        end
        PanelVis = true
    end
    
    if PanelVis ~= LastFrame.PanelVisible then
        if not PanelVis then
            PanelTitle.Visible = false
            for _, L in next, PanelLabels do L.Visible = false end
        end
        LastFrame.PanelVisible = PanelVis
    end
end

local function IsInTriggerFOV(Player)
    local Settings = GetConfig()
    if not Settings then return false end
    
    local MultiPartConfig = Settings['Trigger Bot'] and Settings['Trigger Bot']['Multi Part'] and Settings['Trigger Bot']['Multi Part']['Configuration']
    if MultiPartConfig and MultiPartConfig['Enabled'] then
        return IsInMultiPartZone(Player)
    end
    
    local Method = Settings['Trigger Bot']['Configuration']['FOV Method'] or 'FOV'
    
    if Method == 'Circle' then
        local CircleConfig = Settings['Trigger Bot']['Circle']['Configuration']
        if not CircleConfig or not CircleConfig['Enabled'] then
            return true
        end
        
        local Center = GetReferencePoint()
        local Radius = CircleConfig['Scale'] or 150
        
        if not Player or not Player.Character then
            return false
        end
        
        for _, Part in pairs(Player.Character:GetChildren()) do
            if Part:IsA("BasePart") then
                local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Part.Position)
                if OnScreen then
                    local Dist = math.sqrt((ScreenPos.X - Center.X)^2 + (ScreenPos.Y - Center.Y)^2)
                    if Dist <= Radius then
                        return true
                    end
                end
            end
        end
        
        return false
    end
    
    if Method == 'FOV' then
        local FOVConfig = Settings['Trigger Bot']['FOV']['Configuration']
        if not FOVConfig or not FOVConfig['Enabled'] then
            return true
        end
        local FOVSize = FOVConfig['Size'] or { X = 11, Y = 11, Z = 11 }
        local ScreenCenter = GetScreenCenter()
        return IsScreenPointInTargetBox(Player, ScreenCenter, FOVSize)
    else
        local HitPlayer, HitPart = GetMouseRaycastHit()
        return HitPlayer == Player
    end
end

local function UpdateTriggerBot()
    local Config = GetConfig()
    local TriggerCfg = Config and Config["Trigger Bot"]
    if not TriggerCfg or not TriggerCfg["Configuration"] or not TriggerCfg["Configuration"]["Enabled"] then
        return
    end
    
    if not State.TriggerTargetLocked then
        return
    end
    
    ValidateTarget("Trigger")
    
    local Target = State.Targets.Trigger
    if not Target then
        return
    end
    
    local TargetChar = Target.Character
    if not TargetChar then
        return
    end
    
    if not IsInTriggerFOV(Target) then
        return
    end
    
    if not CheckConditions(Target, "Trigger Bot") then
        return
    end
    
    local Character = LocalPlayer.Character
    if not Character then
        return
    end
    
    local Tool = Character:FindFirstChildOfClass("Tool")
    if not Tool then
        return
    end
    
    if Tool.Name == "[Knife]" or Tool.Name == "Knife" then
        return
    end
    
    local CurrentTime = tick()
    local Cooldown = TriggerCfg["FOV"]["Click Cooldown"] or 0.01
    
    if CurrentTime - state.lastAttackTime >= Cooldown then
        pcall(function()
            Tool:Activate()
        end)
        state.lastAttackTime = CurrentTime
    end
end

local function SetupShootDetection()
    local Config = GetConfig()
    local SDCfg = Config and Config["Trigger Bot"] and Config["Trigger Bot"]["Shoot Detection"]
    if not SDCfg or not SDCfg["Configuration"] or not SDCfg["Configuration"]["Enabled"] then
        return
    end
    
    local MainEvent = ReplicatedStorage:FindFirstChild("MainEvent")
    if MainEvent then
        MainEvent.OnClientEvent:Connect(function(action, ...)
            if action == "ShootGun" and state.shootDetectionEnabled then
                local args = {...}
                local shooter = args[1]
                if shooter and shooter ~= LocalPlayer then
                    state.hostDetected = true
                    
                    local UseTrigger = SDCfg["Configuration"]["Use Trigger"]
                    local UseTriggerEnabled = type(UseTrigger) == 'table' and UseTrigger[1] or UseTrigger
                    
                    if UseTriggerEnabled and state.lockedTarget then
                        State.TriggerTargetLocked = true
                        State.Targets.Trigger = state.lockedTarget
                        state.triggerLastValidTarget = nil
                        state.lastAttackTime = 0
                    end
                end
            end
        end)
    end
end

RunService.PreRender:Connect(function()
    if state.shootDetectionEnabled then
        local newTarget = GetClosestPlayerToCursor(1500, "Trigger")
        if newTarget and CheckConditions(newTarget, "Trigger Bot") then
            state.lockedTarget = newTarget
        else
            state.lockedTarget = nil
            state.hostDetected = false
        end
    end
    
    if state.shootDetectionEnabled and state.hostDetected and state.lockedTarget then
        if CheckConditions(state.lockedTarget, "Trigger Bot") then
            local Config = GetConfig()
            local TriggerCfg = Config and Config["Trigger Bot"]
            if TriggerCfg then
                local SDCfg = TriggerCfg['Shoot Detection']
                if SDCfg and SDCfg['Configuration'] then
                    local UseTrigger = SDCfg['Configuration']['Use Trigger']
                    local UseTriggerEnabled = type(UseTrigger) == 'table' and UseTrigger[1] or UseTrigger
                    
                    if UseTriggerEnabled then
                        State.TriggerTargetLocked = true
                        State.Targets.Trigger = state.lockedTarget
                        state.triggerLastValidTarget = nil
                        
                        local Character = LocalPlayer.Character
                        if Character then
                            local Tool = Character:FindFirstChildOfClass("Tool")
                            if Tool and Tool.Name ~= "[Knife]" then
