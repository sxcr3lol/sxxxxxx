local function SetupMovementFeatures()
    local Character = LocalPlayer.Character
    if not Character then return end
    
    state.PlayerHumanoid = Character:FindFirstChildOfClass("Humanoid")
    if state.PlayerHumanoid then
        state.DefaultWalkSpeed = 16
    end
    
    local ScareConfig = shared.Scare
    if ScareConfig then
        local MovementCfg = ScareConfig['Movement Modifications']
        if MovementCfg and MovementCfg['Configuration'] then
            state.SpeedModEnabled = false
        end
    end
    
    local JumpCfg = shared.Scare and shared.Scare['Jump Modifications'] and shared.Scare['Jump Modifications']['Configuration']
    if JumpCfg then
        if JumpCfg['Spiderman'] and JumpCfg['Spiderman']['Enabled'] then
            SetupSpiderman(Character)
        end
        
        if JumpCfg['Panic Ground'] and JumpCfg['Panic Ground']['Enabled'] then
            SetupPanicGround(Character)
        end
        
        if JumpCfg['AntiFall'] then
            AntiFall(Character)
        end
        
        if JumpCfg['No Jump Cooldown'] then
            NoJumpCooldown(Character)
        end
    end
end

local function SetupCharacter(Character)
    SetupMovementFeatures()
end

if LocalPlayer.Character then
    SetupCharacter(LocalPlayer.Character)
end

