if not isHoodCustoms then
    local GunHandler = nil
    pcall(function()
        GunHandler = require(ReplicatedStorage.Modules.GunHandler)
    end)

    local OriginalGetAim = nil
    if GunHandler then
        OriginalGetAim = GunHandler.getAim
    end

    if GunHandler and OriginalGetAim then
        GunHandler.getAim = function(origin, range)
            local Config = GetConfig()
            local SilentCfg = Config and Config["Silent Aimbot"]
            if not SilentCfg or not SilentCfg["Configuration"] or not SilentCfg["Configuration"]["Enabled"] then
                return OriginalGetAim(origin, range)
            end
            
            if not State.SilentTargetLocked then
                return OriginalGetAim(origin, range)
            end
            
            local Target = State.Targets.Silent
            if not Target then
                return OriginalGetAim(origin, range)
            end
            
            if IsTargetDead(Target) then
                State.Targets.Silent = nil
                State.SilentTargetLocked = false
                state.lastValidTarget = nil
                return OriginalGetAim(origin, range)
            end
            
            if not CheckConditionsExceptVisible(Target, "Silent Aimbot") then
                state.lastValidTarget = Target
                State.Targets.Silent = nil
                return OriginalGetAim(origin, range)
            end
            
            if not CheckConditions(Target, "Silent Aimbot") then
                state.lastValidTarget = Target
                State.Targets.Silent = nil
                return OriginalGetAim(origin, range)
            end
            
            local TargetChar = Target.Character
            local TargetPos = nil
            
            local isClosestPoint = IsSilentHitpartClosestPoint()
            
            if isClosestPoint then
                local result = getClosestPoint(TargetChar)
                if result and result.Position then
                    TargetPos = result.Position
                end
            end
            
            if not TargetPos then
                local TargetHead = TargetChar:FindFirstChild("Head")
                if TargetHead then
                    TargetPos = TargetHead.Position
                else
                    local Root = TargetChar:FindFirstChild("HumanoidRootPart")
                    if Root then
                        TargetPos = Root.Position
                    else
                        return OriginalGetAim(origin, range)
                    end
                end
            end
            
            local Distance = (TargetPos - origin).Magnitude
            local MaxRange = SilentCfg["Configuration"]["Distance"] or 1500
            
            if Distance > MaxRange then
                return OriginalGetAim(origin, range)
            end
            
            local screenPos, onScreen = Camera:WorldToViewportPoint(TargetPos)
            if not onScreen or screenPos.Z <= 0 then
                return OriginalGetAim(origin, range)
            end
            
            local mousePos = UserInputService:GetMouseLocation()
            local deltaX = screenPos.X - mousePos.X
            local deltaY = screenPos.Y - mousePos.Y
            
            local fovCfg = SilentCfg["FOV"] or {}
            local fovEnabled = fovCfg["Configuration"] and fovCfg["Configuration"]["Enabled"]
            if fovEnabled then
                local fovSize = fovCfg["Configuration"]["Size"] or { X = 10, Y = 10, Z = 10 }
                local viewportX, viewportY = Camera.ViewportSize.X, Camera.ViewportSize.Y
                local camFov = Camera.FieldOfView
                local rootPart = TargetChar:FindFirstChild("HumanoidRootPart")
                local rootSize = rootPart and rootPart.Size.Y or 5
                local scale = (rootSize * viewportY) / (screenPos.Z * 2) * 80 / camFov
                local halfW = math.min((fovSize.X or 10) * scale, viewportX * 2) / 2
                local halfH = math.min((fovSize.Y or 10) * scale, viewportY * 2) / 2
                
                if math.abs(deltaX) > halfW or math.abs(deltaY) > halfH then
                    return OriginalGetAim(origin, range)
                end
            else
                local circleCfg = SilentCfg["Circle"] or {}
                local circleEnabled = circleCfg["Configuration"] and circleCfg["Configuration"]["Enabled"]
                if circleEnabled then
                    local radius = circleCfg["Configuration"]["Scale"] or 150
                    if (deltaX * deltaX + deltaY * deltaY) > (radius * radius) then
                        return OriginalGetAim(origin, range)
                    end
                end
            end
            
            local dir = (TargetPos - origin)
            return dir.Unit, math.min(dir.Magnitude, range or 200)
        end
    end
end

if isHoodCustoms then
