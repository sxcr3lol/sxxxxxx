local function UpdateTriggerBot()
    local Config = GetConfig()
    local TriggerCfg = Config and Config["Trigger Bot"]
    if not TriggerCfg or not TriggerCfg["Configuration"] or not TriggerCfg["Configuration"]["Enabled"] then
        return
    end
    
    if not State.TriggerTargetLocked then
        return
    end
    
    ValidateTarget("Trigger")
    
    local Target = State.Targets.Trigger
    if not Target then
        return
    end
    
    local TargetChar = Target.Character
    if not TargetChar then
        return
    end
    
    if not IsInTriggerFOV(Target) then
        return
    end
    
    if not CheckConditions(Target, "Trigger Bot") then
        return
    end
    
    if IsLeftControlHeld() then
        return
    end
    
    local Character = LocalPlayer.Character
    if not Character then
        return
    end
    
    local Tool = Character:FindFirstChildOfClass("Tool")
    if not Tool then
        return
    end
    
    if Tool.Name == "[Knife]" or Tool.Name == "Knife" then
        return
    end
    
    local CurrentTime = tick()
    local CurrentWeapon = Tool.Name
    
    if state.lastWeaponName ~= CurrentWeapon then
        local Delay = GetWeaponSwitchDelay()
        if Delay > 0 then
            state.lastWeaponSwitchTime = CurrentTime
            state.lastWeaponName = CurrentWeapon
            return
        end
        state.lastWeaponName = CurrentWeapon
    end
    
    local Cooldown = GetTriggerCooldown()
    local WeaponDelay = GetWeaponSwitchDelay()
    local TimeSinceWeaponSwitch = CurrentTime - state.lastWeaponSwitchTime
    
    if WeaponDelay > 0 and TimeSinceWeaponSwitch < WeaponDelay then
        return
    end
    
    if CurrentTime - state.lastAttackTime >= Cooldown then
        pcall(function()
            Tool:Activate()
        end)
        state.lastAttackTime = CurrentTime
    end
end

