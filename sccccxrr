    if FOVEnabled and FOVCfg["Configuration"]["Visualize"] and SilentTarget then
        local Char = SilentTarget.Character
        local Root = Char and Char:FindFirstChild("HumanoidRootPart")
        if Root then
            local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Root.Position)
            if OnScreen and ScreenPos.Z > 1 then
                local Size = FOVCfg["Configuration"]["Size"] or { X = 5, Y = 5, Z = 5 }
                local ViewportX, ViewportY = Camera.ViewportSize.X, Camera.ViewportSize.Y
                local CamFOV = Camera.FieldOfView
                local Scale = (Root.Size.Y * ViewportY) / (ScreenPos.Z * 2) * 80 / CamFOV
                local W = math.min((Size.X or 5) * Scale, ViewportX * 2)
                local H = math.min((Size.Y or 5) * Scale, ViewportY * 2)
                SilentFOVBox.Size = Vector2.new(math.floor(W + 0.5), math.floor(H + 0.5))
                SilentFOVBox.Position = Vector2.new(math.floor(ScreenPos.X - W/2 + 0.5), math.floor(ScreenPos.Y - H/2 + 0.5))
                local MousePos = UserInputService:GetMouseLocation()
                local Delta = Vector2.new(ScreenPos.X, ScreenPos.Y) - MousePos
                local InBox = math.abs(Delta.X) <= W/2 and math.abs(Delta.Y) <= H/2
                local BaseColor = FOVCfg["Color"] or Color3.new(1, 1, 1)
                local HoverColor = FOVCfg["Enable Hover Color"] and Color3.new(1, 0, 0) or BaseColor
                SilentFOVBox.Color = InBox and HoverColor or BaseColor
                FOVVis = true
            end
        end
    end
    if FOVVis ~= LastFrame.FOVVisible then
        SilentFOVBox.Visible = FOVVis
        LastFrame.FOVVisible = FOVVis
    end
end

local function UpdateESP()
    local Config = GetConfig()
    local VisualsCfg = Config and Config["Visuals"] or {}
    local NamesCfg = VisualsCfg["Names"] or {}
    local ESPEnabled = VisualsCfg["Enabled"] and NamesCfg["Enabled"]
    local ESPVis = false
    if ESPEnabled then
        local ColorsCfg = VisualsCfg["Colors"] or {}
        local NameColor = ColorsCfg["Names"] or Color3.new(1,1,1)
        local AimedColor = ColorsCfg["Aimed"] or Color3.new(1,0,0)
        local Size = VisualsCfg["Size"] and VisualsCfg["Size"]["Names"] or 12.52
        local Placement = NamesCfg["Placement"] or "Above"
        local OffsetVec = (Placement == "Above") and Vector3.new(0, -2.5, 0) or Vector3.new(0, 0, 0)
        local Method = NamesCfg["Method"] or "Username"
        for _, Plr in next, Players:GetPlayers() do
            if Plr == LocalPlayer then continue end
            if IsTargetDead(Plr) then
                local Draw = NameESPDrawings[Plr]
                if Draw and Draw.Visible then Draw.Visible = false end
                continue
            end
            local Char = Plr.Character
            local Root = Char and Char:FindFirstChild("HumanoidRootPart")
            if not Root then
                local Draw = NameESPDrawings[Plr]
                if Draw and Draw.Visible then Draw.Visible = false end
                continue
            end
            local Pos = Root.Position + OffsetVec
            local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Pos)
            if not OnScreen then
                local Draw = NameESPDrawings[Plr]
                if Draw and Draw.Visible then Draw.Visible = false end
                continue
            end
            if not NameESPDrawings[Plr] then
                local Draw = CreateTextLabel()
                Draw.Outline = true
                Draw.Center = true
                NameESPDrawings[Plr] = Draw
            end
            local Draw = NameESPDrawings[Plr]
            local IsLocked = (Plr == State.Targets.Silent) or (Plr == State.Targets.Trigger)
            Draw.Text = (Method == "Username") and Plr.Name or Plr.DisplayName
            Draw.Size = Size
            Draw.Color = IsLocked and AimedColor or NameColor
            Draw.Position = Vector2.new(math.floor(ScreenPos.X + 0.5), math.floor(ScreenPos.Y + 0.5))
            Draw.Visible = true
            ESPVis = true
        end
    end
    if ESPVis ~= LastFrame.ESPVisible then
        if not ESPVis then
            for _, Draw in next, NameESPDrawings do Draw.Visible = false end
        end
        LastFrame.ESPVisible = ESPVis
    end
end

local function GetSpiderJumpHeight()
    local SpiderConfig = shared.Scare['Jump Modifications']['Configuration']['Walljump']
    if not SpiderConfig then return 50 end
    local CurrentTool = state.WalljumpCharacter and state.WalljumpCharacter:FindFirstChildOfClass('Tool')
    local IsHoldingKnife = CurrentTool and (CurrentTool.Name == '[Knife]' or string.lower(CurrentTool.Name):find('knife'))
    
    if IsHoldingKnife and SpiderConfig['KnifeJumpPower'] then
        return SpiderConfig['KnifeJumpPower']
    end
    
    return SpiderConfig['JumpPower'] or 50
end

local function CheckForNearbyWall(RootPart)
    if not RootPart then return false end
    if not state.WalljumpWallRayParams then
        state.WalljumpWallRayParams = RaycastParams.new()
        state.WalljumpWallRayParams.FilterType = Enum.RaycastFilterType.Exclude
    end
    if state.WalljumpCharacter then
        state.WalljumpWallRayParams.FilterDescendantsInstances = {state.WalljumpCharacter}
    end
    local StartPos = RootPart.Position
    local RootCFrame = RootPart.CFrame
    local RayDirections = {RootCFrame.LookVector, -RootCFrame.LookVector, RootCFrame.RightVector, -RootCFrame.RightVector}
    for _, Direction in next, RayDirections do
        if Workspace:Raycast(StartPos, Direction * 3, state.WalljumpWallRayParams) then
            return true
        end
    end
    return false
end

local function SetupWalljump(Character)
    state.WalljumpCharacter = Character
    state.WalljumpHumanoid = Character:FindFirstChildOfClass("Humanoid")
    if not state.WalljumpHumanoid then return end
    
    state.WalljumpOriginalJumpPower = state.WalljumpHumanoid.JumpPower
    
    if state.WalljumpJumpRequestConnection then
        pcall(function() state.WalljumpJumpRequestConnection:Disconnect() end)
        state.WalljumpJumpRequestConnection = nil
    end
    
    state.WalljumpJumpRequestConnection = UserInputService.JumpRequest:Connect(function()
        if not state.WalljumpCharacter or not state.WalljumpCharacter.Parent then
            if state.WalljumpJumpRequestConnection then
                pcall(function() state.WalljumpJumpRequestConnection:Disconnect() end)
                state.WalljumpJumpRequestConnection = nil
            end
            return
        end
        local SpiderConfig = shared.Scare['Jump Modifications']['Configuration']['Walljump']
        if not SpiderConfig or not SpiderConfig['Enabled'] then
            return
        end
        
        local RootPart = state.WalljumpCharacter:FindFirstChild('HumanoidRootPart')
        if not RootPart then
            return
        end
        
        if state.WalljumpHumanoid:GetState() ~= Enum.HumanoidStateType.Freefall then
            return
        end
        if state.WalljumpFallStartTime == 0 or (tick() - state.WalljumpFallStartTime) < 0.2 then
            return
        end
        if not CheckForNearbyWall(RootPart) then
            return
        end
        
        local WallJumpHeight = GetSpiderJumpHeight()
        state.WalljumpHumanoid.JumpPower = WallJumpHeight
        state.WalljumpHumanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        
        local ResetConnection
        ResetConnection = state.WalljumpHumanoid.StateChanged:Connect(function(_, NewState)
            if NewState == Enum.HumanoidStateType.Freefall or NewState == Enum.HumanoidStateType.Landed then
                pcall(function() ResetConnection:Disconnect() end)
                if state.WalljumpHumanoid then
                    state.WalljumpHumanoid.JumpPower = state.WalljumpOriginalJumpPower
                end
            end
        end)
        table.insert(NoJumpCooldownConnections, ResetConnection)
    end)
    table.insert(NoJumpCooldownConnections, state.WalljumpJumpRequestConnection)
    
    if state.WalljumpHumanoid then
        local StateConnection = state.WalljumpHumanoid.StateChanged:Connect(function(_, NewState)
            if NewState == Enum.HumanoidStateType.Freefall then
                state.WalljumpFallStartTime = tick()
            elseif NewState == Enum.HumanoidStateType.Landed or NewState == Enum.HumanoidStateType.Running then
                state.WalljumpFallStartTime = 0
            end
        end)
        table.insert(NoJumpCooldownConnections, StateConnection)
    end
end

